  {\normalfont\rmfamily\fontsize{30pt}{32pt}\selectfont\color{szInk}\noindent\contentsname\par}%
  \vspace{28pt}%
  \@starttoc{toc}%
}
\newcommand{\np}{\clearpage}
\newcommand{\h}[1]{\chapter{#1}}
\newcommand{\hh}[1]{\section{#1}}
\newcommand{\hhh}[1]{\subsection{#1}}
\newcommand{\hhhh}[1]{\subsubsection{#1}}
\newcommand{\hhhhh}[1]{\paragraph{#1}}
\newcommand{\size}[3][]{}
\newcommand{\margins}[4]{}
