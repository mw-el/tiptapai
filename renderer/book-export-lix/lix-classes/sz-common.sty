\renewcommand{\cftchapfont}{\rmfamily\normalsize\color{szInk}}
\renewcommand{\cftchappagefont}{\rmfamily\normalsize\color{szInk}}
\renewcommand{\cftsecfont}{\rmfamily\small\color{szMuted}}
\renewcommand{\cftsecpagefont}{\sffamily\scriptsize\color{szPale}}
\renewcommand{\cftchapleader}{\cftdotfill{\cftdotsep}}
\renewcommand{\cftdotsep}{6}
\setlength{\cftbeforechapskip}{6pt}
\setlength{\cftbeforesecskip}{2pt}
\setlength{\cftchapnumwidth}{0pt}
\renewcommand{\cftchappresnum}{}
\renewcommand{\cftchapaftersnum}{}

% ---- LiX-API Shims (damit tex-builder.js Body-Renderer ohne Sonderfall laufen) --
